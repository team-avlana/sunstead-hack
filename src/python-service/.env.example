# python-service — environment (copy to .env; .env is gitignored)
#
# config.py auto-loads this file's real counterpart (.env) at startup, so you can
# run `python server.py` without exporting anything. Env vars override config.toml.

# Postgres DSN (Aiven). Single source of truth for the agent + the canvas.
DB_CONNECTION_STRING=postgresql://user:pass@host:5432/defaultdb?sslmode=require

# Azure AI Foundry → Anthropic (Claude, self-hosted). Passed to the analysis-worker.
AZURE_ANTHROPIC_URL=https://<resource>.services.ai.azure.com/anthropic
AZURE_ANTHROPIC_KEY=

# Optional — override only if your Azure deployment names differ from these:
# LLM_PER_SHOT_MODEL=claude-haiku-4-5
# LLM_VIDEO_LEVEL_MODEL=claude-sonnet-4-6

# ElevenLabs (transcription / audio). Used by the analysis-worker too.
ELEVENLABS_API_KEY=

# Azure OpenAI (image generation — Creator Room).
AZURE_OPENAI_URL=https://<resource>.openai.azure.com/openai/v1/
AZURE_OPENAI_KEY=

# yt-dlp auth for sites that wall anonymous downloads (Instagram reels, sometimes
# TikTok). Set exactly ONE; leave both blank to download anonymously. The worker
# inherits these from this .env.
#   YTDLP_COOKIES_FILE — path to a Netscape cookies.txt exported (logged-in) from a
#     browser. Most reliable. Export with a "Get cookies.txt LOCALLY" extension.
#   YTDLP_COOKIES_FROM_BROWSER — read cookies live from a browser you're logged into,
#     e.g. firefox | chrome | safari | edge (optionally chrome:Default).
# Use a throwaway IG account — automated downloads can get an account rate-limited.
# YTDLP_COOKIES_FILE=/Users/you/secrets/instagram_cookies.txt
# YTDLP_COOKIES_FROM_BROWSER=firefox
