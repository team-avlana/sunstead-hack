# Rainy Comms Service — environment

# OpenAI key for IMAGE mode (the default) — gpt-image-1 paints the room.
# Without it, /api/creator-room/image returns 503 and the UI shows the sample.
OPENAI_API_KEY=
# Optional image knobs:
#   RAINY_IMAGE_SIZE=1536x1024   (1024x1024 | 1536x1024 | 1024x1536)
#   RAINY_IMAGE_QUALITY=medium   (low | medium | high)

# Anthropic key for the 3D room code generation (alternative mode) and optional
# image-prompt refinement. Image mode works without it.
ANTHROPIC_API_KEY=

# CORS allow-list (comma-separated origins). Default "*" for local dev.
# In production set the real origins, e.g.:
#   RAINY_ALLOWED_ORIGINS=http://localhost:3000,app-resource://app
RAINY_ALLOWED_ORIGINS=*

# Port for `python app.py` (uvicorn). The canvas-ui expects <host>:<port>/api.
PORT=8787
