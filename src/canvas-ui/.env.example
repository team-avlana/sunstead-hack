# Rainy Canvas UI — environment

# SSE endpoint on the Python Comms Service that streams batched canvas ops
# ("pings"). Leave UNSET in dev to use the built-in mock-comms demo.
# NEXT_PUBLIC_COMMS_SSE_URL=https://comms.local/canvas/stream

# Base HTTP API on the Comms Service for reads ("loads data" from Postgres) and
# for live generation (e.g. the Creator Room — POST <base>/creator-room/generate).
# The browser/WebView NEVER talks to Postgres or Anthropic directly — both go
# through here. Leave UNSET to use the built-in procedural Creator Room only.
# For local dev with the Python service on :8787 -> http://localhost:8787/api
# NEXT_PUBLIC_COMMS_API_URL=https://comms.local/api
