{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python Debugger: Current File",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal"
    },
    {
      "name": "python-service",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "server:app",
        "--host", "127.0.0.1",
        "--port", "9000",
        "--reload"
      ],
      "cwd": "${workspaceFolder}/src/python-service",
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "APP_CONFIG": "${workspaceFolder}/src/python-service/config.toml"
      },
      "console": "integratedTerminal",
      "justMyCode": false
    }
  ]
}